#########################################
# OPENROUTER — Configurações da API
#########################################

# Sua API key do OpenRouter
OPENROUTER_API_KEY=coloque_sua_chave_aqui

# Modelo padrão usado pela aplicação
NLP_MODEL=gpt-4o-mini

# Identificação recomendada pelo OpenRouter
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=RAG-System


#########################################
# NEO4J — Configurações do Banco Vetorial
#########################################

# Conexão com o Neo4j (docker-compose expõe 7687)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password


#########################################
# RAG — Configurações gerais
#########################################

# Pasta que contém os PDFs a serem ingeridos
PDF_FOLDER=./files

# Nome do modelo de embeddings (se quiser alterar)
EMBEDDING_MODEL=text-embedding-3-small


#########################################
# LOGGING / DEBUG
#########################################

# true / false
DEBUG_RAG=false
LOG_LEVEL=info